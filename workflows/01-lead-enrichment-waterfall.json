      "position": [
        460,
        300
      ]
    },
    {
      "parameters": {
        "conditions": {
          "options": {
            "caseSensitive": true,
            "leftValue": "",
            "typeValidation": "strict"
          },
          "conditions": [
            {
              "id": "cond-apollo-01",
              "leftValue": "={{ $json.person.employment_history.length }}",
              "rightValue": 0,
              "operator": {
                "type": "number",
                "operation": "gt"
              }
            }
          ],
          "combinator": "and"
        },
        "options": {}
      },
      "id": "a1b2c3d4-0003-4003-8003-aabbcc000003",
      "name": "Apollo Hit?",
      "type": "n8n-nodes-base.if",
      "typeVersion": 2,
      "position": [
        680,
        300
      ]
    },
    {
      "parameters": {
        "method": "GET",
        "url": "=https://api.hunter.io/v2/email-finder?domain={{ $(\"Webhook\").item.json.company_domain }}&first_name={{ $(\"Webhook\").item.json.first_name }}&last_name={{ $(\"Webhook\").item.json.last_name }}&api_key={{ $env.HUNTER_API_KEY }}",
        "options": {}
      },
      "id": "a1b2c3d4-0004-4004-8004-aabbcc000004",
      "name": "Hunter.io Fallback",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        680,
        480
      ]
    },
    {
      "parameters": {
        "assignments": {
          "assignments": [
            {
              "id": "set-01",
              "name": "enrichment_source",
