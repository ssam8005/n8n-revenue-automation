      "typeVersion": 3.4,
      "position": [
        900,
        480
      ]
    },
    {
      "parameters": {
        "operation": "update",
        "base": {
          "__rl": true,
          "value": "{{ $env.AIRTABLE_BASE_ID }}",
          "mode": "id"
        },
        "table": {
          "__rl": true,
          "value": "Leads",
          "mode": "name"
        },
        "id": "={{ $(\"Webhook\").item.json.airtable_record_id }}",
        "columns": {
          "mappingMode": "defineBelow",
          "value": {
            "Enrichment Source": "={{ $json.enrichment_source }}",
            "Enriched Email": "={{ $json.enriched_email }}",
            "Title": "={{ $json.enriched_title }}",
            "LinkedIn URL": "={{ $json.enriched_linkedin }}",
            "Enrichment Confidence": "={{ $json.enrichment_confidence }}",
            "Enrichment Status": "complete",
            "Enriched At": "={{ $now.toISO() }}"
          },
          "matchingColumns": [
            "id"
          ],
          "schema": []
        },
        "options": {}
      },
      "id": "a1b2c3d4-0007-4007-8007-aabbcc000007",
      "name": "Airtable Update Lead",
      "type": "n8n-nodes-base.airtable",
      "typeVersion": 2.1,
      "position": [
        1120,
        380
      ]
    },
    {
      "parameters": {
