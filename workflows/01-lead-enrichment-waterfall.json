            },
            {
              "id": "set-04",
              "name": "enriched_linkedin",
              "value": "={{ $json.person.linkedin_url }}",
              "type": "string"
            },
            {
              "id": "set-05",
              "name": "enriched_seniority",
              "value": "={{ $json.person.seniority }}",
              "type": "string"
            },
            {
              "id": "set-06",
              "name": "enrichment_confidence",
              "value": "high",
              "type": "string"
            }
          ]
        },
        "options": {}
      },
      "id": "a1b2c3d4-0005-4005-8005-aabbcc000005",
      "name": "Set Apollo Data",
      "type": "n8n-nodes-base.set",
      "typeVersion": 3.4,
      "position": [
        900,
        300
      ]
    },
    {
      "parameters": {
        "assignments": {
          "assignments": [
            {
              "id": "set-07",
              "name": "enrichment_source",
              "value": "hunter",
              "type": "string"
            },
            {
              "id": "set-08",
              "name": "enriched_email",
              "value": "={{ $json.data.email }}",
              "type": "string"
            },
            {
              "id": "set-09",
              "name": "enrichment_confidence",
              "value": "={{ $json.data.score >= 70 ? 'medium' : 'low' }}",
              "type": "string"
            },
            {
              "id": "set-10",
              "name": "enriched_title",
              "value": "={{ $json.data.position }}",
              "type": "string"
            }
          ]
        },
        "options": {}
      },
      "id": "a1b2c3d4-0006-4006-8006-aabbcc000006",
      "name": "Set Hunter Data",
